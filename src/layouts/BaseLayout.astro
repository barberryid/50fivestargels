---
import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileMenuOverlay from '../components/MobileMenuOverlay.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  jsonLd?: Record<string, any> | Record<string, any>[];
  imageAlt?: string;
  /** Set false to skip the shared Header/Footer chrome (page supplies its own). */
  chrome?: boolean;
}

const { title, description, canonical, image, type, noindex, jsonLd, imageAlt, chrome = true } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- TODO: add analytics once a GA/Plausible property exists for this site
         (mirror the production-hostname guard used in 50fivestarhotels). -->
    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      type={type}
      noindex={noindex}
      jsonLd={jsonLd}
      imageAlt={imageAlt}
    />
    <slot name="head-extra" />
  </head>
  <body>
    {chrome && <Header />}
    <slot />
    {chrome && <Footer />}
    <MobileMenuOverlay />
  </body>
</html>
