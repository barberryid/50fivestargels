---
import BaseLayout from '../layouts/BaseLayout.astro';
import { websiteJsonLd, publisherJsonLd, defaultDescription } from '../lib/seo';

const cards = [
  {
    tint: 'var(--color-tint-pink)',
    title: 'Money, made concrete',
    body: 'Cost per gram of carbohydrate, plus what a 12-week training block really costs you in gels versus DIY mix.',
  },
  {
    tint: 'var(--color-tint-lavender)',
    title: 'Buy, make — or both',
    body: 'DIY mixes compared directly against commercial gels, instead of only spitting out a recipe.',
  },
  {
    tint: 'var(--color-tint-sky)',
    title: 'An honest gut-load estimate',
    body: 'A concentration warning presented as an estimate, not a lab reading — with clear guidance on what to sip and what to chase with water.',
  },
];

const fuelingLinks = [
  { label: 'AI fuelling prompt generator', href: '/ai-race-fuel-prompt-generator/' },
  { label: 'Marathon fuelling guide', href: '/marathon-gel-guide/' },
  { label: 'HYROX fuelling guide', href: '/hyrox-gel-guide/' },
  { label: 'Commercial gel comparison', href: '/running-gel-cost-calculator/?mode=commercial' },
];
---

<BaseLayout
  title="Stop overpaying for race fuel — 50FiveStarGels"
  description={defaultDescription}
  canonical="/"
  jsonLd={[websiteJsonLd(), publisherJsonLd()]}
  chrome={false}
>
  <Fragment slot="head-extra">
    <style>
      .gate-skip #entry-gate {
        display: none !important;
      }
    </style>
  </Fragment>

  <script is:inline>
    if (sessionStorage.getItem('gels-gate-entered') === '1') {
      document.documentElement.classList.add('gate-skip');
    }
  </script>

  <div style="font-family:var(--font-body);background:var(--color-bg);color:var(--color-text);min-height:100vh;overflow-x:hidden;">
    <!-- ======================= ENTRY GATE ======================= -->
    <div
      id="entry-gate"
      style="position:fixed;inset:0;z-index:60;background:var(--color-bg);overflow:hidden;transition:transform 700ms cubic-bezier(0.65,0,0.35,1);will-change:transform;"
    >
      <div style="position:absolute;top:24px;left:32px;display:flex;align-items:center;gap:12px;">
        <img src="/images/logo-star.svg" alt="" width="34" height="34" />
        <span style="font-family:var(--font-serif);font-size:17px;line-height:0.95;letter-spacing:-0.01em;text-transform:uppercase;color:var(--color-accent);">50Five<br />Star<br />Gels</span>
      </div>

      <div style="position:absolute;top:48%;left:2vw;transform:translateY(-58%);z-index:3;pointer-events:none;font-family:var(--font-serif);font-size:clamp(72px,14.5vw,270px);line-height:0.78;text-transform:uppercase;color:var(--color-accent);letter-spacing:-0.02em;white-space:nowrap;">Bounce<br />the gel</div>
      <div style="position:absolute;top:54%;right:2vw;transform:translateY(-38%);z-index:3;pointer-events:none;text-align:right;font-family:var(--font-serif);font-size:clamp(72px,14.5vw,270px);line-height:0.78;text-transform:uppercase;color:var(--color-accent);letter-spacing:-0.02em;white-space:nowrap;">to get<br />in!</div>

      <div id="gate-gel" style="position:absolute;left:50%;top:50%;transform:translate(-50%,-52%);cursor:pointer;display:flex;flex-direction:column;align-items:center;user-select:none;-webkit-tap-highlight-color:transparent;z-index:2;">
        <div id="gate-gel-anim" class="gel-bounce-target">
          <svg width="min(28vw, 42vh, 300px)" height="auto" viewBox="0 0 240 360" aria-label="Energy gel packet">
            <path d="M74 10 L166 10 L174 40 L66 40 Z" fill="#E33529"></path>
            <path d="M64 36 L176 36 L178 48 L62 48 Z" fill="#000000"></path>
            <path d="M172 22 C186 26 196 40 192 52 C190 60 182 62 178 56" fill="none" stroke="#E33529" stroke-width="7" stroke-linecap="round"></path>
            <circle cx="196" cy="66" r="7" fill="#E33529"></circle>
            <circle cx="208" cy="86" r="4.5" fill="#E33529"></circle>
            <path d="M58 54 C58 50 62 46 68 46 L172 46 C178 46 182 50 182 54 L196 240 C202 300 166 344 120 344 C74 344 38 300 44 240 Z" fill="#F6F6ED" stroke="#000000" stroke-width="4"></path>
            <path d="M76 66 C70 110 66 180 74 250 C80 296 92 316 100 322" fill="none" stroke="#000000" stroke-width="4" stroke-linecap="round" opacity="0.85"></path>
            <path d="M166 70 C172 120 176 190 168 254" fill="none" stroke="#000000" stroke-width="4" stroke-linecap="round" opacity="0.6"></path>
            <path d="M96 60 C94 84 92 110 92 136" fill="none" stroke="#000000" stroke-width="4" stroke-linecap="round" opacity="0.35"></path>
            <g transform="translate(120, 168)">
              <path d="M0 -52 L15.2 -16.4 L52 -16.4 L22.8 6.8 L34 44 L0 22 L-34 44 L-22.8 6.8 L-52 -16.4 L-15.2 -16.4 Z" fill="#E33529" stroke="#000000" stroke-width="4" stroke-linejoin="round"></path>
              <text x="0" y="104" text-anchor="middle" font-family="Bayon, sans-serif" font-size="64" fill="#E33529">50</text>
            </g>
          </svg>
        </div>
        <div class="gel-shadow" style="width:150px;height:20px;border-radius:50%;background:#000000;opacity:0.22;filter:blur(8px);margin-top:8px;"></div>
      </div>

      <div style="position:absolute;left:50%;bottom:26px;transform:translateX(-50%);text-align:center;z-index:3;">
        <div id="gate-counter" style="font-family:var(--font-serif);font-size:26px;letter-spacing:-0.01em;text-transform:uppercase;color:var(--color-accent);">5 bounces to get in</div>
        <div id="gate-quip" style="font-family:var(--font-body);font-size:14px;font-weight:500;color:#000000;opacity:0.6;margin-top:6px;min-height:20px;">It wants to be bounced. They all do.</div>
        <a
          id="gate-skip"
          href="#top"
          style="display:inline-block;margin-top:12px;font-family:var(--font-body);font-size:13px;font-weight:600;text-transform:uppercase;letter-spacing:0.04em;color:var(--color-green);text-decoration:underline;text-underline-offset:3px;cursor:pointer;"
          >In a hurry? Skip the warm-up →</a
        >
      </div>
    </div>

    <!-- ======================= HERO ======================= -->
    <section id="top" style="position:relative;min-height:100vh;overflow:hidden;background:var(--color-bg);">
      <header style="position:absolute;top:0;left:0;right:0;z-index:10;display:flex;align-items:flex-start;justify-content:space-between;padding:24px 32px;gap:24px;">
        <div style="display:flex;align-items:center;gap:12px;">
          <img src="/images/logo-star.svg" alt="" width="34" height="34" />
          <span style="font-family:var(--font-serif);font-size:17px;line-height:0.95;letter-spacing:-0.01em;text-transform:uppercase;color:var(--color-accent);">50Five<br />Star<br />Gels</span>
        </div>
        <nav style="display:flex;align-items:center;gap:36px;padding-top:10px;">
          <a href="#calculator" class="gel-nav-link" style="font-family:var(--font-serif);font-size:19px;letter-spacing:-0.01em;text-transform:uppercase;color:var(--color-accent);text-decoration:none;">Calculator</a>
          <a href="#what-you-get" class="gel-nav-link" style="font-family:var(--font-serif);font-size:19px;letter-spacing:-0.01em;text-transform:uppercase;color:var(--color-accent);text-decoration:none;">What you get</a>
          <a href="#coming-next" class="gel-nav-link" style="font-family:var(--font-serif);font-size:19px;letter-spacing:-0.01em;text-transform:uppercase;color:var(--color-accent);text-decoration:none;">Get fueling</a>
        </nav>
        <a
          href="/running-gel-cost-calculator/"
          class="gel-pill-btn"
          style="font-family:var(--font-body);font-size:14px;font-weight:500;letter-spacing:0.04em;text-transform:uppercase;background:var(--color-accent);color:var(--color-bg);padding:14px 26px;border-radius:9999px;margin-top:4px;text-decoration:none;transition:background 160ms ease;"
          >Open calculator</a
        >
      </header>

      <div style="position:absolute;top:48%;left:2vw;transform:translateY(-55%);z-index:3;pointer-events:none;font-family:var(--font-serif);font-size:clamp(80px,16vw,300px);line-height:0.78;text-transform:uppercase;color:var(--color-accent);letter-spacing:-0.02em;white-space:nowrap;">The<br />right<br />gel</div>
      <div style="position:absolute;top:58%;right:2vw;transform:translateY(-42%);z-index:3;pointer-events:none;text-align:right;font-family:var(--font-serif);font-size:clamp(80px,16vw,300px);line-height:0.78;text-transform:uppercase;color:var(--color-accent);letter-spacing:-0.02em;white-space:nowrap;">changes<br />the race!</div>

      <div id="hero-gel" title="Go on, bounce it" style="position:absolute;left:39%;top:54%;transform:translate(-50%,-50%);z-index:2;cursor:pointer;display:flex;flex-direction:column;align-items:center;user-select:none;-webkit-tap-highlight-color:transparent;">
        <div id="hero-gel-anim" class="gel-bounce-target">
          <img src="/images/trainers.png" alt="Pair of racing trainers" style="width:min(24vw, 32vh, 300px);height:auto;display:block;" />
        </div>
        <div style="width:220px;height:20px;border-radius:50%;background:#000000;opacity:0.18;filter:blur(10px);margin-top:-10px;"></div>
      </div>

      <div style="position:absolute;left:32px;bottom:28px;z-index:3;font-family:var(--font-body);font-size:13px;font-weight:500;letter-spacing:0.04em;color:#000000;opacity:0.65;text-transform:uppercase;">Free · no sign-up · results shareable by link</div>
      <div style="position:absolute;right:32px;bottom:28px;z-index:3;font-family:var(--font-serif);font-size:17px;letter-spacing:0.02em;text-transform:uppercase;color:var(--color-green);">Scroll ↓</div>
    </section>

    <!-- ======================= STATEMENT ======================= -->
    <section style="background:var(--color-tint-pink);">
      <div style="max-width:1100px;margin:0 auto;padding:clamp(72px,10vw,140px) clamp(1rem,4vw,3rem);text-align:center;">
        <div style="font-family:var(--font-serif);font-size:clamp(38px,5.2vw,84px);line-height:0.85;text-transform:uppercase;color:var(--color-accent);letter-spacing:-0.02em;">Race fuel,<br />priced honestly.</div>
      </div>
    </section>

    <!-- ======================= CTA ======================= -->
    <section id="calculator" style="background:var(--color-green);">
      <div style="max-width:1280px;margin:0 auto;padding:clamp(64px,8vw,110px) clamp(1rem,4vw,3rem);display:grid;grid-template-columns:minmax(0,1.4fr) minmax(0,1fr);gap:48px;align-items:center;">
        <h2 style="font-family:var(--font-serif);font-size:clamp(42px,5vw,80px);line-height:0.82;text-transform:uppercase;color:var(--color-bg);margin:0;letter-spacing:-0.02em;">Stop overpaying for race fuel.</h2>
        <div>
          <p style="font-family:var(--font-body);font-size:17px;font-weight:500;line-height:1.65;color:var(--color-bg);margin:0 0 28px;">Compare gels by cost per gram of carbohydrate and calculate your own DIY race mix for marathon, half marathon, HYROX and long training — with editable prices that work in any currency.</p>
          <a
            href="/running-gel-cost-calculator/"
            class="gel-cta-btn"
            style="display:inline-block;font-family:var(--font-body);font-size:15px;font-weight:500;letter-spacing:0.04em;text-transform:uppercase;background:var(--color-accent);color:var(--color-bg);padding:18px 32px;border-radius:9999px;text-decoration:none;transition:transform 160ms ease,background 160ms ease;"
            >Open the calculator →</a
          >
        </div>
      </div>
    </section>

    <!-- ======================= WHAT YOU GET ======================= -->
    <section id="what-you-get" style="background:var(--color-bg-soft);">
      <div style="max-width:1280px;margin:0 auto;padding:clamp(72px,9vw,130px) clamp(1rem,4vw,3rem);">
        <h2 style="font-family:var(--font-serif);font-size:clamp(56px,9vw,150px);line-height:0.8;text-transform:uppercase;color:var(--color-accent);margin:0 0 clamp(36px,5vw,64px);letter-spacing:-0.02em;">What<br />you get</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;">
          {
            cards.map((card, i) => (
              <div class="gel-card" style={`background:${card.tint};border-radius:24px;padding:40px 32px;transition:transform 180ms ease;`}>
                <div style="width:52px;height:52px;border-radius:9999px;background:var(--color-accent);color:var(--color-bg);display:flex;align-items:center;justify-content:center;font-family:var(--font-serif);font-size:24px;margin-bottom:22px;">
                  {i + 1}
                </div>
                <h3 style="font-family:var(--font-serif);font-size:34px;line-height:0.85;text-transform:uppercase;letter-spacing:-0.01em;margin:0 0 14px;color:#000000;">{card.title}</h3>
                <p style="font-family:var(--font-body);font-size:15px;font-weight:500;line-height:1.65;color:#000000;margin:0;">{card.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ======================= GET FUELING ======================= -->
    <section id="coming-next" style="background:var(--color-accent);overflow:hidden;">
      <div style="max-width:1280px;margin:0 auto;padding:clamp(64px,8vw,110px) clamp(1rem,4vw,3rem);">
        <h2 style="font-family:var(--font-serif);font-size:clamp(56px,9vw,150px);line-height:0.8;text-transform:uppercase;color:var(--color-bg);margin:0 0 clamp(32px,4vw,56px);letter-spacing:-0.02em;">Get<br />fueling</h2>
        <div style="display:flex;flex-wrap:wrap;gap:14px;margin-bottom:32px;">
          {
            fuelingLinks.map((link) => (
              <a
                href={link.href}
                class="gel-fueling-link"
                style="font-family:var(--font-serif);font-size:21px;letter-spacing:0;text-transform:uppercase;color:var(--color-accent);background:var(--color-bg);padding:14px 28px;border-radius:9999px;text-decoration:none;transition:transform 160ms ease,background 160ms ease,color 160ms ease;"
              >
                {link.label}
              </a>
            ))
          }
        </div>
        <p style="font-family:var(--font-body);font-size:16px;font-weight:500;line-height:1.65;color:rgba(243,243,233,0.9);max-width:64ch;margin:0;">Same rule as the calculator: numbers you can check, estimates labelled as estimates, and nothing that reads like a brochure.</p>
      </div>
    </section>

    <!-- ======================= FOOTER ======================= -->
    <footer style="background:#000000;color:rgba(243,243,233,0.7);">
      <div style="max-width:1280px;margin:0 auto;padding:32px clamp(1rem,4vw,3rem);display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:16px;">
        <div style="display:flex;align-items:center;gap:10px;">
          <img src="/images/logo-star.svg" alt="" width="24" height="24" />
          <span style="font-family:var(--font-serif);font-size:17px;letter-spacing:0;text-transform:uppercase;color:var(--color-bg);">50FiveStarGels</span>
        </div>
        <span style="font-family:var(--font-body);font-size:13px;font-weight:500;">© 2026 · Prices are estimates — check them against your own shop.</span>
      </div>
    </footer>
  </div>

  <style>
    .gel-nav-link:hover {
      color: #000 !important;
    }
    .gel-pill-btn:hover {
      background: #000 !important;
    }
    #gate-skip:hover {
      color: #000 !important;
    }
    .gel-cta-btn:hover {
      background: #000 !important;
      transform: translateY(-2px);
    }
    .gel-card:hover {
      transform: translateY(-6px);
    }
    .gel-fueling-link:hover {
      background: #000 !important;
      color: var(--color-bg) !important;
      transform: translateY(-2px);
    }
    html {
      scroll-behavior: smooth;
    }
  </style>

  <script>
    const GATE_KEY = 'gels-gate-entered';
    const NEEDED = 5;
    const QUIPS = [
      'It wants to be bounced. They all do.',
      "That's one. Carbs loading…",
      'Good pop. Isotonic, even.',
      'Your glycogen stores thank you.',
      "One more and you're through the tape.",
    ];

    const gate = document.getElementById('entry-gate');
    const gateGel = document.getElementById('gate-gel');
    const gateGelAnim = document.getElementById('gate-gel-anim');
    const counterEl = document.getElementById('gate-counter');
    const quipEl = document.getElementById('gate-quip');
    const skipLink = document.getElementById('gate-skip');
    const heroGel = document.getElementById('hero-gel');
    const heroGelAnim = document.getElementById('hero-gel-anim');

    let bounces = 0;
    let entered = false;
    let popToggle = false;

    function popClass(toggle: boolean) {
      return toggle ? 'is-popping-a' : 'is-popping-b';
    }

    function settle(target: HTMLElement) {
      target.classList.remove('is-popping-a', 'is-popping-b');
    }

    function updateCounter() {
      const left = Math.max(0, NEEDED - bounces);
      counterEl!.textContent = left === NEEDED ? `${NEEDED} bounces to get in` : `${left} to go`;
      quipEl!.textContent = QUIPS[Math.min(bounces, QUIPS.length - 1)];
    }

    function enterSite() {
      if (entered) return;
      entered = true;
      counterEl!.textContent = 'Fuelled. In you go.';
      (counterEl as HTMLElement).style.color = 'var(--color-green)';
      quipEl!.textContent = '';
      (gate as HTMLElement).style.transform = 'translateY(-100%)';
      sessionStorage.setItem(GATE_KEY, '1');
      setTimeout(() => {
        (gate as HTMLElement).style.display = 'none';
      }, 700);
    }

    if (gate && sessionStorage.getItem(GATE_KEY) === '1') {
      (gate as HTMLElement).style.display = 'none';
      entered = true;
    }

    if (gateGel && gateGelAnim) {
      gateGel.addEventListener('click', () => {
        if (entered) return;
        bounces += 1;
        popToggle = !popToggle;
        settle(gateGelAnim as HTMLElement);
        void (gateGelAnim as HTMLElement).offsetWidth;
        gateGelAnim.classList.add(popClass(popToggle));
        updateCounter();
        if (bounces >= NEEDED) {
          setTimeout(enterSite, 650);
        }
      });
      gateGelAnim.addEventListener('animationend', () => settle(gateGelAnim as HTMLElement));
    }

    if (skipLink) {
      skipLink.addEventListener('click', (e) => {
        e.preventDefault();
        enterSite();
      });
    }

    if (heroGel && heroGelAnim) {
      let heroToggle = false;
      heroGel.addEventListener('click', () => {
        heroToggle = !heroToggle;
        settle(heroGelAnim as HTMLElement);
        void (heroGelAnim as HTMLElement).offsetWidth;
        heroGelAnim.classList.add(popClass(heroToggle));
      });
      heroGelAnim.addEventListener('animationend', () => settle(heroGelAnim as HTMLElement));
    }
  </script>
</BaseLayout>
