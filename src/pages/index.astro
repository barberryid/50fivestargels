---
import BaseLayout from '../layouts/BaseLayout.astro';
import { websiteJsonLd, publisherJsonLd, defaultDescription } from '../lib/seo';

const differentiators = [
  {
    title: 'Money, made concrete',
    body: 'Cost per gram of carbohydrate, plus what a 12-week training block really costs you in gels versus DIY mix.',
  },
  {
    title: 'Buy, make — or both',
    body: 'DIY mixes compared directly against commercial gels, instead of only spitting out a recipe.',
  },
  {
    title: 'An honest gut-load estimate',
    body: 'A concentration warning presented as an estimate, not a lab reading — with clear guidance on what to sip and what to chase with water.',
  },
];
---

<BaseLayout
  title="Stop overpaying for race fuel — 50FiveStarGels"
  description={defaultDescription}
  canonical="/"
  jsonLd={[websiteJsonLd(), publisherJsonLd()]}
>
  <main>
    <section style="max-width:880px;margin:0 auto;padding:clamp(48px,8vw,96px) 20px 40px;text-align:center;">
      <p class="fuel-eyebrow">Race fuel, priced honestly</p>
      <h1 style="font-size:clamp(2.6rem,6vw,4.5rem);line-height:1.02;margin:14px 0 0;">
        Stop overpaying for race fuel.
      </h1>
      <p style="font-size:clamp(1.05rem,1.6vw,1.25rem);line-height:1.65;color:var(--color-text-muted);max-width:56ch;margin:22px auto 0;">
        Compare gels by cost per gram of carbohydrate and calculate your own DIY race mix for marathon, half marathon,
        HYROX and long training — with editable prices that work in any currency.
      </p>
      <div style="margin-top:30px;display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
        <a href="/running-gel-cost-calculator/" class="fuel-btn fuel-btn-accent" style="font-size:15px;"
          >Open the Race Fuel Cost Calculator →</a
        >
      </div>
      <p style="font-family:var(--font-sans);font-size:12.5px;color:var(--color-text-muted);margin-top:16px;">
        Free · no sign-up · results shareable by link
      </p>
    </section>

    <section style="max-width:1080px;margin:0 auto;padding:24px 20px 10px;">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px;">
        {
          differentiators.map((item) => (
            <div class="fuel-card" style="padding:26px;">
              <h2 style="font-family:var(--font-sans);font-size:1.15rem;font-weight:800;margin:0;">{item.title}</h2>
              <p style="color:var(--color-text-muted);line-height:1.65;margin:10px 0 0;">{item.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section style="max-width:880px;margin:0 auto;padding:40px 20px 30px;text-align:center;">
      <p style="font-family:var(--font-sans);font-size:13px;font-weight:700;color:var(--color-text-muted);">
        Coming next: AI fuelling prompt generator · marathon &amp; HYROX fuelling guides · commercial gel comparison
      </p>
    </section>
  </main>
</BaseLayout>
