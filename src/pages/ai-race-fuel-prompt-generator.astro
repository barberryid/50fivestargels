---
import BaseLayout from '../layouts/BaseLayout.astro';
import PromptGenerator from '../components/promptgen/PromptGenerator';
import { webPageJsonLd, canonicalUrl } from '../lib/seo';

const title = 'AI Race Fuel Prompt Generator - personalised fuelling prompts for any AI assistant';
const description =
  'Answer a short tactile questionnaire and get a copy-paste prompt for Claude, ChatGPT or any AI assistant - find gels in your country, compare commercial vs DIY, or build a marathon or HYROX fuelling plan.';

const webAppJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'AI Race Fuel Prompt Generator',
  url: canonicalUrl('/ai-race-fuel-prompt-generator/'),
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
  description,
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="/ai-race-fuel-prompt-generator/"
  chrome={false}
  jsonLd={[webAppJsonLd, webPageJsonLd({ title, description, path: '/ai-race-fuel-prompt-generator/' })]}
>
  <Fragment slot="head-extra">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Playfair+Display:wght@600&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <PromptGenerator client:load />
</BaseLayout>
