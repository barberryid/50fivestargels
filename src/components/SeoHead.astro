---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  jsonLd?: Record<string, any> | Record<string, any>[];
  imageAlt?: string;
}

import { canonicalUrl as makeCanonicalUrl, imageUrl, siteName, SITE_URL } from '../lib/seo';

const {
  title,
  description,
  canonical,
  image,
  type = 'website',
  noindex = false,
  jsonLd,
  imageAlt = siteName,
} = Astro.props;
const canonicalHref = canonical
  ? makeCanonicalUrl(new URL(canonical, SITE_URL).pathname)
  : makeCanonicalUrl(Astro.url.pathname);
const socialImage = imageUrl(image);
const robots = noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large';
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={siteName} />
<meta name="theme-color" content="#F3F3E9" />
<meta name="format-detection" content="telephone=no" />
<link rel="canonical" href={canonicalHref} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="robots" content={robots} />
<meta property="og:locale" content="en_US" />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalHref} />
{socialImage && <meta property="og:image" content={socialImage} />}
{socialImage && <meta property="og:image:alt" content={imageAlt} />}
<meta name="twitter:card" content={socialImage ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{socialImage && <meta name="twitter:image" content={socialImage} />}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Bayon&family=Inter:wght@400;500;600;700;800&display=swap"
/>
{jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
