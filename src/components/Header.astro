---
const links = [
  { href: '/running-gel-cost-calculator/', label: 'Cost Calculator' },
];
---

<header
  style="position:sticky;top:0;z-index:60;background:rgba(247,244,235,.88);backdrop-filter:blur(10px);border-bottom:1px solid var(--color-border);"
>
  <div
    style="max-width:1180px;margin:0 auto;height:64px;padding:0 clamp(18px,4vw,40px);display:flex;align-items:center;justify-content:space-between;gap:16px;"
  >
    <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none;">
      <img src="/favicon.svg" alt="" width="28" height="28" style="display:block;border-radius:7px;" />
      <span
        style="font-family:var(--font-serif);font-weight:600;font-size:17px;color:var(--color-text);white-space:nowrap;"
        >50FiveStarGels</span
      >
    </a>
    <nav style="display:flex;align-items:center;gap:6px;" aria-label="Main navigation">
      {
        links.map((link) => (
          <a
            href={link.href}
            style="padding:9px 13px;border-radius:8px;color:var(--color-text-muted);font-family:var(--font-sans);font-size:13px;font-weight:700;text-decoration:none;"
          >
            {link.label}
          </a>
        ))
      }
      <a href="/running-gel-cost-calculator/" class="fuel-btn fuel-btn-accent" style="font-size:13px;"
        >Work out my race fuel →</a
      >
    </nav>
  </div>
</header>
