---
interface Props {
  head: string[];
  rows: string[][];
}

const { head, rows } = Astro.props;
---

<div style="overflow-x:auto;margin-top:14px;">
  <table style="width:100%;border-collapse:separate;border-spacing:0;border:1.5px solid var(--color-border);border-radius:8px;overflow:hidden;background:var(--color-bg-card);">
    <thead>
      <tr>
        {head.map((label) => (
          <th style="text-align:left;padding:12px 14px;background:var(--color-accent);color:#fff;font-family:var(--font-sans);font-size:0.88rem;">
            {label}
          </th>
        ))}
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr>
          <td style="padding:12px 14px;border-top:1px solid var(--color-border);color:var(--color-text-muted);">
            {row[0]}
          </td>
          <td style="padding:12px 14px;border-top:1px solid var(--color-border);color:var(--color-text);font-weight:800;text-align:right;">
            {row[1]}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
